// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema","views"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public"]
}

// models
model Product {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(255)
  company     String   @db.VarChar(255)
  description String   @db.Text
  is_featured Boolean
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  user_id     String   @db.VarChar(255)
  is_active   Boolean  @default(true)
  base_price  Decimal  @db.Decimal(10, 2) // Default/base price for the product

  averageRating AverageProductRating?
  is_custom    Boolean  @default(false)
  collection   Collection
  prices       ProductPrice[]
  sizes        ProductSize[]
  material     Material[]
  favorites    Favorite[]
  reviews      Review[]
  images       ProductImage[]
  categories   ProductCategory[]
  custom_order CustomOrder[]
  cart_items   CartItem[]

  @@index([is_featured, is_active])
  @@schema("public")
}

model ProductPrice {
  id           String    @id @default(uuid())
  price        Decimal   @db.Decimal(10, 2) // The actual price amount
  type         String    @default("STANDARD") @db.VarChar(255) // STANDARD, SALE, WHOLESALE, SEASONAL, etc.
  name         String?   @db.VarChar(255) // Optional name for this price (e.g., "Summer Sale", "Bulk Discount")
  start_date   DateTime? // When this price becomes active
  end_date     DateTime? // When this price expires
  min_quantity Int? // Minimum quantity for this price to apply
  is_active    Boolean   @default(true)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  // Relations
  product_id String  @db.VarChar(255)
  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id, is_active])
  @@index([type])
  @@index([start_date, end_date])
  @@schema("public")
}

model ProductImage {
  id            String  @id @default(uuid())
  is_main_image Boolean @default(false)
  image_url     String  @db.VarChar(255)
  product_id    String  @db.VarChar(255)
  product       Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@schema("public")
}

model ProductCategory {
  id          String @id @default(uuid())
  name        String @db.VarChar(255)
  description String @db.Text

  // Many-to-many with products
  products Product[]

  @@schema("public")
}

model ProductSize {
  id             String @id @default(uuid())
  size           String @db.VarChar(255) // e.g., "S", "M", "L", "XL", "Custom"
  quantity       Int    @default(0)
  price_modifier Int    @default(0) // Additional cost for certain sizes

  // Relations
  product_id String  @db.VarChar(255)
  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  cart_items CartItem[]

  @@schema("public")
}

model Material {
  id         String  @id @default(uuid())
  name       String  @default("Cotton") @db.VarChar(255)
  //Relations
  product_id String  @db.VarChar(255)
  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@schema("public")
}

model Favorite {
  id         String   @id @default(uuid())
  user_id    String   @db.VarChar(255)
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_id String   @db.VarChar(255)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
  @@schema("public")
}

model Review {
  id               String   @id @default(uuid())
  user_id          String   @db.VarChar(255)
  rating           Int
  comment          String   @db.VarChar(255)
  author_name      String   @db.VarChar(255)
  author_image_url String   @db.VarChar(255)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  product          Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_id       String   @db.VarChar(255)

  @@index([user_id])
  @@schema("public")
}

model Cart {
  id                String     @id @default(uuid())
  user_id           String     @unique @db.VarChar(255)
  cart_items        CartItem[]
  num_items_in_cart Int        @default(0)

  // pricing 
  cart_total  Decimal @default(0) @db.Decimal(10, 2)
  shipping    Decimal     @default(5)
  tax         Decimal     @default(0)
  tax_rate    Decimal   @default(0.1)
  order_total Decimal     @default(0)

  email       String?     @db.VarChar(255)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
  @@schema("public")
}

model CartItem {
  id     String @id @default(uuid())
  amount Int

  // For ready-made products 
  product    Product? @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_id String?  @db.VarChar(255)

  size       ProductSize? @relation(fields: [size_id], references: [id], onDelete: Cascade)
  size_id    String?      @db.VarChar(255)

  //Cart relation
  cart    Cart   @relation(fields: [cart_id], references: [id], onDelete: Cascade)
  cart_id String @db.VarChar(255)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@schema("public")
}

model Order {
  id       String @id @default(uuid())
  user_id  String? @db.VarChar(255)
  products Int    @default(0) //numItemsInCart // number of Items In Cart
  tax      Decimal    @default(0)
  shipping Decimal    @default(0)
  email    String     @db.VarChar(255)

  order_total Decimal     @default(0)
  is_paid     Boolean @default(false)

  order_number String      @unique @db.VarChar(255)
  status       OrderStatus @default(PENDING)
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt

  square_order_id String?  @unique // To match webhooks
  payment_link_id String?  // To track the link source

  order_items OrderItem[]

  @@index([status, created_at])
  @@schema("public")
}

model OrderItem {
  id            String   @id @default(uuid())
  order_id      String
  product_id    String
  quantity      Int
  price         Decimal
  product_name  String
  product_image String?
  size          String?
  created_at    DateTime @default(now())

  order Order @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@schema("public")
}

// Enums for better type safety
enum OrderType {
  READY_MADE
  CUSTOM

  @@schema("public")
}

enum Collection {
  MEN
  WOMEN

  @@schema("public")
}

enum Occasion {
  TRADITIONAL
  WEDDING
  CASUAL
  FORMAL

  @@schema("public")
}

enum OrderStatus {
  PENDING
  ORDER_PLACED
  PROCESSING
  DISPATCHED
  COMPLETED
  CANCELLED

  @@schema("public")
}

//custom Order
model CustomOrder {
  id      String @id @default(uuid())
  user_id String @db.VarChar(255)

  product    Product?  @relation(fields: [product_id], references: [id])
  product_id String?   @db.VarChar(255)
  order_type OrderType

  // Step 1: select collection
  collection Collection
  occasion   Occasion?

  // Step 2: custom design image uploads
  custom_images      CustomImage[]
  custom_order_notes String?       @db.Text

  // Step 3: Measurements
  is_self_measured   Boolean @default(false)
  liability_accepted Boolean @default(false) // Only for self-measured
  staff_notes        String? @db.VarChar(255) // For in-store measurements

  // Step 5: Contact info
  email           String?     @db.VarChar(255)
  contact_info    ContactInfo? @relation(fields: [contact_info_id], references: [id])
  contact_info_id String?

  special_instructions String? @db.Text

  // Pricing
  customization_fee Decimal @db.Decimal(10, 2)
  total_price       Decimal @db.Decimal(10, 2)

  // Relations
  measurements Measurement[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@schema("public")
}

model ContactInfo {
  id            String @id @default(uuid())
  first_name    String @db.VarChar(255)
  last_name     String @db.VarChar(255)
  contact_email String @db.VarChar(255)
  contact_phone String @db.VarChar(255)
  address       String @db.VarChar(255)
  city          String @db.VarChar(255)

  // Relations
  custom_orders CustomOrder[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@schema("public")
}

model CustomImage {
  id              String      @id @default(uuid())
  is_main_image   Boolean     @default(false)
  image_url       String      @db.VarChar(255)
  custom_order_id String      @db.VarChar(255)
  custom_order    CustomOrder @relation(fields: [custom_order_id], references: [id], onDelete: Cascade)

  @@schema("public")
}

model Measurement {
  id          String  @id @default(uuid())
  user_id     String  @db.VarChar(255)
  name        String  @db.VarChar(255) // e.g., "chest", "waist", "sleeve_length", "shoulder_width"
  value       Float
  unit        String  @default("inches") @db.VarChar(255)
  is_required Boolean @default(true)

  // Relations
  custom_order_data_id String      @db.VarChar(255)
  custom_order         CustomOrder @relation(fields: [custom_order_data_id], references: [id], onDelete: Cascade)

  @@schema("public")
}

//users
model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String?
  bio       String?
  image     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userRoles UserRole[]
  
  @@schema("public")
}

model Role {
  id              String          @id @default(cuid())
  name            String          @unique
  description     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  userRoles       UserRole[]
  rolePermissions RolePermission[]
  
  @@schema("public")
}

model Permission {
  id              String          @id @default(cuid())
  name            String          @unique
  description     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  rolePermissions RolePermission[]
  
  @@schema("public")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@schema("public")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@schema("public")
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@schema("public")
}

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  category    String
  type        String   @default("string") // string, number, boolean, json
  description String?
  isPublic    Boolean  @default(false) // Whether this setting can be accessed by non-admin users
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isPublic])
  @@schema("public")
}

// Add Materialized View here
view AverageProductRating {
  product_id     String @unique
  average_rating Float?
  review_count   Int?

  product        Product @relation(fields: [product_id], references: [id])

  @@schema("public")
  @@map("AverageProductRating") 
}